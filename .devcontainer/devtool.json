{
  "name": "Dicey Pets",
  "image": "mcr.microsoft.com/devcontainers/java:17",
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y ttyd && javac *.java",
  "forwardPorts": [
    3000
  ],
  "portsAttributes": {
    "3000": {
      "label": "Dicey Pets",
      "onAutoForward": "openBrowser"
    }
  },
  "postStartCommand": "ttyd -p 3000 java Main"
}